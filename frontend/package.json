{
  "name": "ancient-bridge-visualization-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{vue,js,ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{vue,js,ts,css}\"",
    "lint": "eslint src --ext .vue,.js,.ts --fix",
    "lint:check": "eslint src --ext .vue,.js,.ts"
  },
  "dependencies": {
    "@tresjs/core": "^5.7.0",
    "echarts": "^6.0.0",
    "three": "^0.183.2",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.27.0",
    "prettier": "^3.3.3",
    "vite": "^5.3.4"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "endOfLine": "lf"
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "node": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:vue/vue3-recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "plugins": ["vue"],
    "rules": {
      "vue/multi-word-component-names": "off",
      "no-console": "warn",
      "no-unused-vars": "error"
    }
  }
}